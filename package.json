{
  "name": "meal-preparation",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --base-href=/meal-prep/",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed",
    "deploy": "ng deploy --base-href=/meal-prep/",
    "worker:dev": "cd cf-worker && npm run dev",
    "worker:deploy": "cd cf-worker && npm run deploy"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "mammoth": "^1.12.0",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "angular-cli-ghpages": "^3.0.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
